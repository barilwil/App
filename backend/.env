# ── TTS Engine ────────────────────────────────────────────────────────────────
# "piper" (default, local, offline) or "elevenlabs" (API, demo mode)
TTS_ENGINE=piper

# Piper paths (only needed if TTS_ENGINE=piper)
# Download ARM64 binary from: https://github.com/rhasspy/piper/releases
# Download voice model from:  https://huggingface.co/rhasspy/piper-voices
PIPER_BIN=./piper/piper.exe
PIPER_MODEL=./piper/en_US-amy-medium.onnx

# ElevenLabs (only needed if TTS_ENGINE=elevenlabs)
ELEVENLABS_API_KEY= #here
ELEVENLABS_VOICE=21m00Tcm4TlvDq8ikWAM # change
ELEVENLABS_MODEL=eleven_turbo_v2 # change

# ── STT / Whisper ─────────────────────────────────────────────────────────────
# Model: tiny | base | small (recommended) | medium | large-v3
WHISPER_MODEL=small
# Device: cuda (Jetson GPU) | cpu (testing on non-Jetson)
WHISPER_DEVICE=cpu
# Compute type: int8 (half VRAM, minimal accuracy loss) | float16 | float32
WHISPER_COMPUTE=int8

USE_WAKE_WORD=false
# ── Wake Word (Porcupine) ─────────────────────────────────────────────────────
# Get a free access key at: console.picovoice.ai
#PORCUPINE_ACCESS_KEY=

# Built-in placeholder keyword (no .ppn file needed)
# Options: computer, jarvis, hey google, hey siri, alexa, ok google, picovoice, porcupine
#PORCUPINE_KEYWORD=computer

# Custom "Hey Circuit" wake word (.ppn file from console.picovoice.ai)
# Leave blank to use built-in keyword above
#PORCUPINE_KEYWORD_PATH=./wake_word/hey_circuit.ppn

# Jetson: set to true to use Silero VAD instead of energy-based VAD
USE_SILERO_VAD=false

# ── Audio Device ─────────────────────────────────────────────────────────────
# Leave blank to use system default microphone
# Set to device index if you need a specific USB mic on the Jetson
AUDIO_DEVICE_INDEX=

# ── LLM ──────────────────────────────────────────────────────────────────────
CIRCUIT_LLM_BASE_URL=http://127.0.0.1:8001
